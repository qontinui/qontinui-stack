# syntax=docker/dockerfile:1.7
#
# qontinui canonical-DB migrator — one-shot `alembic upgrade head`.
#
# Build context: D:/qontinui-root/  (the parent of qontinui-stack/, qontinui-web/,
# and qontinui-schemas/). docker-compose.yml sets `build.context: ..` so all
# three sibling repos are visible to COPY.
#
# Why a build-time COPY instead of a runtime bind-mount:
#   - Self-contained image works in CI/cloud where the host doesn't have
#     qontinui-web/ checked out next to qontinui-stack/.
#   - Reproducible: the same image always loads the same alembic chain and
#     model graph; no "works on my machine" drift from the host filesystem.
#   - Layer cache invalidates only on the directories we actually copy
#     (qontinui-web/backend/{alembic,app}, qontinui-schemas/), not on the
#     entire qontinui-root tree.
#
# Why we don't `poetry install --only main` against qontinui-web/backend:
#   qontinui-web/backend depends on the `qontinui` path dep, which pins torch
#   and torchvision from the pytorch-cu128 wheel index (RTX 5090 / Blackwell
#   sm_120). Installing those runs to ~3 GB of ML mass — none of it needed to
#   apply alembic migrations. We instead use a curated `migrator/pyproject.toml`
#   that lists exactly the deps env.py + the model graph need (see that file's
#   header comment for the rationale). Image stays well under the 500 MB target.

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    POETRY_NO_INTERACTION=1 \
    POETRY_VIRTUALENVS_CREATE=false \
    POETRY_CACHE_DIR=/tmp/poetry-cache

# psycopg2-binary ships its own libpq, so we don't need libpq-dev.
# Slim image already has libstdc++ which pgvector's wheel needs.
# `tini` gives us correct PID-1 signal handling for a one-shot.
RUN apt-get update \
    && apt-get install -y --no-install-recommends tini curl \
    && rm -rf /var/lib/apt/lists/*

# Pin Poetry to the 2.x line. qontinui-web/backend's poetry.lock is generated
# by Poetry 2.3.2 (`# automatically @generated by Poetry 2.3.2`) — the 1.8.x
# series can't read 2.x lockfiles, so the original spec's "1.8.x" pin is
# incompatible with the rest of the monorepo. We're not consuming that lock
# from here (we have our own curated pyproject), but matching majors keeps
# the migrator aligned with how everyone else resolves deps.
ARG POETRY_VERSION=2.1.3
RUN pip install --no-cache-dir "poetry==${POETRY_VERSION}"

WORKDIR /app

# ---- Layer 1: qontinui-schemas (path dep target) ------------------------------
# qontinui-schemas changes far less often than qontinui-web/backend/app, so
# COPY it first to keep its layer cached across most rebuilds.
COPY qontinui-schemas/pyproject.toml /qontinui-schemas/pyproject.toml
COPY qontinui-schemas/README.md /qontinui-schemas/README.md
COPY qontinui-schemas/src /qontinui-schemas/src

# ---- Layer 2: migrator pyproject + dep install --------------------------------
# Copy only the dep manifest first so `poetry install` can be cached when
# the manifest is unchanged.
COPY qontinui-stack/migrator/pyproject.toml /app/pyproject.toml

# `--no-root` because this isn't a real package (package-mode=false anyway).
# `--only main` keeps dev deps out (none defined today, but defensive).
RUN poetry install --no-root --only main \
    && rm -rf /tmp/poetry-cache

# ---- Layer 3: alembic config + migration scripts ------------------------------
# alembic.ini and alembic/ change when new revisions land — copy after deps
# so a new revision doesn't bust the install layer.
COPY qontinui-web/backend/alembic.ini /app/alembic.ini
COPY qontinui-web/backend/alembic /app/alembic

# ---- Layer 4: app/ (model graph) ---------------------------------------------
# The single most-churned source — copy last so other layers stay cached on
# unrelated app changes.
COPY qontinui-web/backend/app /app/app

# ---- Entrypoint --------------------------------------------------------------
COPY qontinui-stack/migrator/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# ---- Healthcheck script (alembic-status sidecar) -----------------------------
# Long-running observers reuse this image with `command: ["sleep", "infinity"]`
# and a docker healthcheck that calls /alembic_at_head.sh. See
# qontinui-stack/docker-compose.yml `alembic-status` service.
COPY qontinui-stack/migrator/alembic_at_head.sh /alembic_at_head.sh
RUN chmod +x /alembic_at_head.sh

# Smoke-check at build time: the model graph must import cleanly. If a future
# qontinui-web change adds an import that needs a dep we don't ship, this
# fails the build instead of erroring at `docker compose up` time.
RUN python -c "import sys; sys.path.insert(0, '/app'); from app.db.base_class import *; print('model graph loaded')"

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
