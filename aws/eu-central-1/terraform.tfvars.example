# ─────────────────────────────────────────────────────────────────────────
# eu-central-1 env — example tfvars.
#
# Copy to terraform.tfvars and fill in. The REAL terraform.tfvars is
# gitignored and is created at apply time with the secret values injected
# (coord_github_webhook_secret, signup_allowlist, budget_alert_email, the
# real image URIs, etc.). NEVER commit the filled-in terraform.tfvars — it
# carries secrets. This *.example file is the committed, secret-free template.
# ─────────────────────────────────────────────────────────────────────────

region      = "eu-central-1"
environment = "staging"

# DNS — must already exist in Route53. This eu env SHARES the staging domain
# + zone with the us-east-1 env during the region migration (Phase 1 stands
# up the ALB+cert only — traffic DNS stays on us-east-1 via
# manage_traffic_dns=false in main.tf).
domain_name = "staging.qontinui.io"
# route53_zone_id MUST be Z02792161EHR967BO9804 — the staging.qontinui.io
# Route53 hosted zone.
route53_zone_id = "Z02792161EHR967BO9804"

# Coord image. This value is used ONLY on the initial `terraform apply`
# that creates the task definition for the first time. Ongoing coord
# deploys SHA-pin a fresh task-definition revision via
# `../scripts/push-coord-image.sh` and update the ECS service directly;
# terraform is not re-applied for routine image rolls.
#
# `:staging` is therefore a moving alias maintained by the push script
# (it tags every build as both `:<sha>` and `:staging`) — safe to leave
# in this default since the live task def will be SHA-pinned anyway.
# NOTE: eu-central-1 ECR registry — the image must be pushed to the
# eu-central-1 registry (per-region ECR) before apply.
coord_image_uri = "<aws-account-id>.dkr.ecr.eu-central-1.amazonaws.com/qontinui-coord:staging"

# GitHub webhook shared secret. Use `openssl rand -hex 32` to generate.
coord_github_webhook_secret = "REPLACE-ME"

# Sizing — defaults are fine for staging. Bump for prod.
# postgres_instance_class = "db.t4g.micro"
# postgres_multi_az       = false
# redis_node_type         = "cache.t4g.micro"
# coord_desired_count     = 1
