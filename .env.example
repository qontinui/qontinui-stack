# Copy to .env and customize for your environment.
# All values shown are dev-only defaults — change for any non-local deployment.

# PostgreSQL
POSTGRES_USER=qontinui_user
POSTGRES_PASSWORD=qontinui_dev_password
POSTGRES_DB=qontinui_db
POSTGRES_PORT=5433

# Redis
REDIS_PORT=6380
REDIS_PASSWORD=qontinui_dev_redis

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101

# Coordinator service
COORD_PORT=9870
# GITHUB_WEBHOOK_SECRET=set-me-to-the-shared-secret-from-the-github-webhook
# COORD_RUST_LOG=qontinui_coord=debug,axum=debug,tower_http=info

# bazel-remote (content-addressed build cache; Row 10 Item 4)
# Backed by MinIO bucket BAZEL_REMOTE_BUCKET. HTTP port serves REST
# CAS/AC; gRPC port serves REAPI (reserved for Item 7+).
BAZEL_REMOTE_HTTP_PORT=9094
BAZEL_REMOTE_GRPC_PORT=9095
BAZEL_REMOTE_BUCKET=qontinui-bazel-remote
BAZEL_REMOTE_MAX_SIZE_GIB=50
BAZEL_REMOTE_S3_ENDPOINT=minio:9000
# Host-side URL the supervisor pool / canonical_diff_hash callers point at.
# In-stack consumers should use http://bazel-remote:80 instead.
BAZEL_REMOTE_HTTP_URL=http://localhost:9094
